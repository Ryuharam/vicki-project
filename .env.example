# --- Webhook Configuration ---
# 웹훅 이벤트 검증을 위한 시크릿 키
WEBHOOK_SECRET=your_webhook_secret_here

# --- GitHub Auth / App Configuration ---
# GitHub App의 클라이언트 ID
GITHUB_CLIENT_ID=your_github_client_id_here
# 깃허브 인증용 프라이빗 키(.pem 등) 파일의 절대 경로
GITHUB_KEY_FILE_PATH=./keys/github-private-key.pem

# --- AI Provider & Models ---
# 사용할 AI 공급자 (예: google, anthropic, ollama, openai)
PROVIDER=google

# Google Gemini 모델명 (예: gemini-1.5-pro, gemini-1.5-flash)
GOOGLE_MODEL=gemini-1.5-pro
# Google AI Studio에서 발급받은 API 키
GOOGLE_API_KEY=AIzaSy...

# Anthropic Claude 모델명 (예: claude-3-5-sonnet-20240620)
ANTHROPIC_MODEL=claude-3-5-sonnet-20240620
# Anthropic 콘솔에서 발급받은 API 키
ANTHROPIC_API_KEY=sk-ant-...

# 로컬 Ollama 모델명 (예: llama3, mistral)
OLLAMA_MODEL=llama3

# --- Vector Database & Embedding ---
# 텍스트 임베딩에 사용할 모델명 (예: text-embedding-3-small)
EMBED_MODEL=text-embedding-3-small
# 벡터 데이터베이스 호스트 주소 (예: localhost 또는 데이터베이스 컨테이너 이름)
VECTOR_DB_HOST=localhost
# 벡터 데이터베이스 포트 번호 (예: Milvus 19530, Qdrant 6333, Chroma 8000)
VECTOR_DB_PORT=19530

# --- Docker Configuration ---
# 도커 허브(Docker Hub) 사용자 계정 이름
DOCKER_USERNAME=your_docker_username
